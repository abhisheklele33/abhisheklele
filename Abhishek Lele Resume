  <!-- HERO -->
  <div class="hero">
    <div class="hero-content">
      <div class="hero-tag">// Mechanical Engineer & Medical Device Engineer</div>
      <h1>Abhishek<br><span class="accent">Lele</span></h1>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;animation:fadeUp 0.6s 0.5s both;">
        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/2/28/UC_San_Diego_seal.svg/240px-UC_San_Diego_seal.svg.png" alt="UCSD Seal" style="width:48px;height:48px;opacity:0.9;filter:drop-shadow(0 0 8px rgba(0,212,255,0.4));">
        <div style="border-left:1px solid var(--border);padding-left:16px;">
          <div style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:2px;">UC SAN DIEGO</div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:1px;">SCHOOL OF ENGINEERING</div>
        </div>
      </div>
      <div class="hero-subtitle">M.Eng. Bioengineering (Medical Device Engineering) · UC San Diego<br>B.Tech. Mechanical Engineering · MIT World Peace University</div>
      <p class="hero-desc">
        Building at the intersection of biomechanics, medical devices, and embedded systems.
        From smart insoles to haptic gloves — I engineer solutions that bridge the gap between
        clinical insight and physical hardware.
      </p>
      <div class="hero-links">
